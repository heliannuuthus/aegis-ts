{
  "name": "@aegis/sdk",
  "version": "1.0.0",
  "description": "Aegis Auth SDK - 支持 Web 和小程序的认证 SDK",
  "type": "module",
  "packageManager": "pnpm@10.31.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./web": {
      "import": "./dist/web.js",
      "require": "./dist/web.cjs",
      "types": "./dist/web.d.ts"
    },
    "./taro": {
      "import": "./dist/taro.js",
      "require": "./dist/taro.cjs",
      "types": "./dist/taro.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@tarojs/taro": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@tarojs/taro": {
      "optional": true
    }
  },
  "dependencies": {
    "paseto-ts": "^2.0.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^1.0.0",
    "prettier": "^3.3.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0"
  },
  "keywords": [
    "auth",
    "oauth2",
    "pkce",
    "aegis",
    "miniprogram",
    "wechat",
    "taro"
  ],
  "author": "heliannuuthus",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/heliannuuthus/aegis-sdk"
  }
}
